# michael-vibe-trading 环境变量模板
#
# 这是模板，不要填真实密钥。Railway 上在 service Variables 配置实际值。
# 本地开发可 cp .env.example .env 后填入，再 export 加载。

# ─────────── 必填 ───────────

# MCP Bearer + OAuth 登录共享密钥。任意长字符串，>=32 字符。
# 用于:① MCP 客户端 Bearer  ② OAuth /authorize 页面口令
# 不要和 ADMIN_AUTH_TOKEN 共用 — 泄露此 token 不应打开 /_debug/* 运维通道
MCP_AUTH_TOKEN=

# 管理员凭据,**独立**于 MCP_AUTH_TOKEN,专门给 /_debug/* 用。
# 不设值时所有 /_debug/* 端点**不注册**(生产默认安全)。
# 想用运维端点时:在 Railway env 加 ADMIN_AUTH_TOKEN + 把 ENABLE_DEBUG_ENDPOINTS=true
ADMIN_AUTH_TOKEN=
# 总开关 — 即便设了 ADMIN_AUTH_TOKEN,也要这个为 true 才会注册 /_debug/* 路由
ENABLE_DEBUG_ENDPOINTS=false

# Sequoia-X 扫描硬超时(秒,默认 300)。防 sina/eastmoney 接口卡死拖死 worker。
SEQUOIA_HARD_TIMEOUT=300

# 热点事件分析(auto-researcher)硬超时(秒,默认 180)。
# 总耗时 = LLM 路由(~10s) + 新闻抓取(~10s) + 主分析(~60s)。
HOT_EVENT_TIMEOUT=180

# 每日定时热点推送 — bot 自动从新闻流挑事件 → 跑分析 → 推送到指定群。
# DAILY_HOT_EVENT_CHAT_ID 空则禁用 scheduler。
DAILY_HOT_EVENT_CHAT_ID=
# 推送时间(逗号分隔小时,北京时间)。默认 "10,15" = 上午10点 + 下午3点
DAILY_HOT_EVENT_HOURS=10,15
# 时区偏移小时,默认 8(北京)
DAILY_HOT_EVENT_TZ_OFFSET=8

# KHunter pipeline 配置
# 整体硬超时(秒,默认 14400 = 4 小时):scan ~5min + Top10 swarm 串行 ~2-3 小时
# 如果改用 llm 模式(下面),可降到 600
KHUNTER_HARD_TIMEOUT=14400
# 辩论模式:swarm (真实投委会 swarm 串行,慢/深) | llm (单 LLM 调用并行,快/浅)
# 默认 swarm,跟「确保飞书文档信息齐全」目标对齐。可改 llm 提速到 5 分钟。
KHUNTER_DEBATE_MODE=swarm
# swarm 模式下,单只股 swarm 上限(秒,默认 1800 = 30 分钟)
KHUNTER_SWARM_TIMEOUT_PER_RUN=1800
# KHunter scripts dir 覆盖(默认通过 SkillsLoader 自动发现,仅本地调试时设)
KHUNTER_SCRIPTS_DIR=
# KHunter workspace 目录(factor_analysis 包所在),默认 /app
KHUNTER_WORKSPACE=

# 工作日盘前 KHunter 自动推送
# DAILY_KHUNTER_CHAT_ID 空则禁用 scheduler
DAILY_KHUNTER_CHAT_ID=
# 工作日盘前推送小时(逗号分隔,默认 "8" 即北京时间 08:00)
DAILY_KHUNTER_HOURS=8
# 是否仅工作日推(true=跳过周末,默认 true)
DAILY_KHUNTER_WEEKDAYS_ONLY=true
# Sequoia-X scripts 目录覆盖(默认通过 SkillsLoader 自动发现)。
# 仅本地开发或异常环境下设。
SEQUOIA_SCRIPTS_DIR=
# Sequoia-X workspace 目录(factor_analysis 包所在),默认 /app(容器内)。
SEQUOIA_WORKSPACE=

# 持久化状态目录(Railway Volume 挂载路径)。
# 不设值时:swarm runs + OAuth registry 都落 ephemeral 文件系统,每次 deploy 擦盘。
# 设值时(推荐):Railway dashboard → Volumes → 添加 Volume,挂载到此路径,
# .swarm/runs / oauth_clients.json 等状态会在 deploy 间持久保留。
# 例:STATE_DIR=/app/data,然后在 Railway 加一个 Volume mount 到 /app/data。
STATE_DIR=

# LLM provider（swarm 主调用 + 摘要 + 游资视角）。
# DeepSeek v4-pro 是默认 reasoning model。也可以换 OpenAI 兼容端点。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LANGCHAIN_MODEL_NAME=deepseek-v4-pro

# ─────────── 选填：HTTP 服务 ───────────
PORT=8000
# OAuth issuer 用，必须是公网 HTTPS 可达地址（Railway 默认 *.up.railway.app）
PUBLIC_BASE_URL=

# ─────────── 选填：飞书 Bot ───────────
# 三个之一缺失,/feishu/events 路由根本不会注册(防裸跑):
#   LARK_APP_ID + LARK_APP_SECRET + (FEISHU_VERIFICATION_TOKEN 或 FEISHU_ENCRYPT_KEY)
LARK_APP_ID=
LARK_APP_SECRET=
# 飞书「事件订阅」页拷贝的 Verification Token。**强制要求**,否则 webhook 禁用。
FEISHU_VERIFICATION_TOKEN=
# 飞书「加密事件」开启后才有 — 与 VERIFICATION_TOKEN 任一即可
FEISHU_ENCRYPT_KEY=
# webhook 请求 body 上限(byte),超过返 413。
FEISHU_WEBHOOK_MAX_BYTES=65536
# webhook 每个 IP 每 60 秒最大请求数,超过返 429。0 = 不限。
FEISHU_WEBHOOK_RATE_LIMIT=30
# 用户没指定 preset 时的默认值
FEISHU_DEFAULT_PRESET=investment_committee
# 是否用 LLM 路由解析意图（false 时只走简单关键词匹配）
FEISHU_USE_LLM_ROUTER=true
# 每个新生成的飞书 docx 的默认链接共享权限
# tenant_readable: 组织内可阅读（推荐 — 群成员直接看,无需申请）
# tenant_editable: 组织内可编辑
# anyone_readable: 互联网可阅读（慎用,会被搜索引擎收录）
# closed:           关闭,只有添加为成员的人能看(Feishu 默认)
# 需要 bot app 启用 docs:doc 或 drive:drive 权限并在开放平台发布新版本激活
FEISHU_DOC_SHARE_ENTITY=tenant_readable
# 用户云盘文件夹 token —— 若设置,bot 新建的每个 docx 都落在这个文件夹下,
# 文档自动继承文件夹的「分享/可见」权限。
# 前提:文件夹所有者要在飞书 UI 把这个文件夹分享给 bot 并给「可编辑」权限
# 不设(留空)时 docx 落 bot 自己的云盘,需要 drive:drive scope 才能开链接共享
FEISHU_DRIVE_FOLDER_TOKEN=

# ─────────── 选填：Notion 同步 ───────────
# DATABASE_ID 和 PARENT_PAGE_ID 二选一，DATABASE 优先
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
NOTION_API_VERSION=2022-06-28

# ─────────── 选填：游资观点 addendum ───────────
# auto: LLM 路由从 10 个游资里选 1-2 位最相关的(默认)
# fixed:xiao-eyu,chen-xiao-qun: 强制用列出的游资,跳过路由
# off: 关闭游资观点附加
GURU_VIEW_MODE=auto
# 每次最多生成几位游资观点(1-3,默认 2)
GURU_VIEW_MAX=2

# ─────────── 选填：备用 LLM provider ───────────
# DEEPSEEK_* 没填时，按 OPENROUTER → OPENAI 顺序 fallback
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
